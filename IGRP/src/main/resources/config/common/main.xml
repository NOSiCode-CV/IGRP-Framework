<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>

	<comment>All basic and advanced IGRP configuration parameters</comment>
	
	<!-- igrpweb environment parameter (dev|test|sta|prod) -->
	<entry key="igrp.env">prod</entry>
	
	<entry key="igrp.datasource.connection-name">hibernate-igrp-core</entry>
	
	<!-- igrpweb workspace parameter (absolute path) -->
	<entry key="igrp.workspace">../..</entry> 
	
	<!-- igrpweb authentication type parameter (db|ldap|oauth2-openid) -->
	<entry key="igrp.authentication_type">db</entry>

	<!-- igrpweb password recovery parameter: enable or not the password recovery funcionality -->
	<entry key="igrp.pwdRecover">false</entry>
	<!-- For login template change
	<entry key="igrp.login.template">ds-beta</entry> -->

	<entry key="igrp.authentication.govcv.enbaled">true</entry>

	<!-- igrpweb identity server (autentika.gov.cv) service -->
	<entry key="ids.autentika.enabled">true</entry>
	<entry key="ids.autentika.RemoteUserStoreManagerService-wsdl-url">https://autentika.gov.cv/services/RemoteUserStoreManagerService?wsdl</entry>
	<entry key="ids.autentika.admin-usn">admin.igrp@nosi.cv</entry>
	<entry key="ids.autentika.admin-pwd">!GRP&amp;ad!m!n</entry>

	<!-- Identity server parameters -->
	<entry key="ids.oauth2-openid.client_id">SwfKPzC_RMSzMI6MfssFbZYHnZUa</entry>
	<entry key="ids.oauth2-openid.client_secret">SUWpWZrSx9rDGvN03xIZ997l6RAa</entry>
	<entry key="ids.oauth2-openid.endpoint.token">https://autentika.gov.cv/oauth2/token</entry>
	<entry key="ids.oauth2-openid.endpoint.user">https://autentika.gov.cv/oauth2/userinfo</entry>
	<entry key="ids.oauth2-openid.endpoint.authorize">https://autentika.gov.cv/oauth2/authorize</entry>
	<entry key="ids.oauth2-openid.endpoint.redirect_uri">http://localhost/IGRP/index.jsp</entry>
	<entry key="ids.oauth2-openid.endpoint.logout">https://autentika.gov.cv/oidc/logout</entry>
	<!-- Ldap configuration parameters -->
	<entry key="ldap.ad.url"></entry>
	<entry key="ldap.ad.username"></entry>
	<entry key="ldap.ad.password"></entry>
	<entry key="ldap.ad.base"></entry>
	<entry key="ldap.ad.authentication_filter"></entry>
	<entry key="ldap.ad.entryDN"></entry>
	
	<!-- Default configuration parameters of server smtp (gmail) -->
	<entry key="java.net.preferIPv4Stack"></entry>
	<entry key="mail.smtp.host"></entry>
	<entry key="mail.smtp.auth"></entry>
	<entry key="mail.smtp.port"></entry>
	<entry key="mail.user"></entry>
	<entry key="mail.password"></entry>
	
	 
	
	<!-- igrpweb as a kriol platform --> 
	<!--  -->
	<!-- Allows to addrole to user when register a new one through identity server (autentika.gov.cv) service -->
	<entry key="kriol.addrole.user">false</entry>
	
	
	
	<!-- Standalone config -->	
	<entry key="igrp.mode.standalone.enabled">false</entry>
	<entry key="igrp.embedded.server.servlet.context-path">/IGRP</entry>
	<entry key="igrp.embedded.server.http.port">8080</entry>
	
</properties>
